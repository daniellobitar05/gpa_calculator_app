rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sub-collections: courses and assignments belong to user
      match /courses/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /assignments/{assignmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Instructor queries students list: any authenticated user can read user profiles
    // (only name, email, role exposed — safe for academic use)
    match /users/{userId} {
      allow read: if request.auth != null;
    }

    // Shared assignments: any logged-in user can read; only instructors can create/delete
    // Students can update (to add their submission to the submissions map)
    match /shared_assignments/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Grades: instructor writes, student reads their own
    match /grades/{gradeId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.studentId == request.auth.uid ||
         resource.data.instructorId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource.data.instructorId == request.auth.uid;
    }
  }
}
